# 1. Airflow 기본 이미지 사용
FROM apache/airflow:2.10.4-python3.11

# 2. 루트 권한으로 시스템 패키지 설치 (여기가 핵심!)
USER root
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    apt-get install -y openjdk-17-jdk && \
    libglib2.0-0 libnss3 libnspr4 libdbus-1-3 libatk1.0-0 libatk-bridge2.0-0 \
    libcups2 libdrm2 libxcb1 libxkbcommon0 libatspi2.0-0 libx11-6 \
    libxcomposite1 libxdamage1 libxext6 libxfixes3 libxrandr2 libgbm1 \
    libpango-1.0-0 libcairo2 libasound2 && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*
ENV JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64
ENV PATH=$JAVA_HOME/bin:$PATH
# 3. 다시 airflow 유저로 변경 (보안 및 pip 설치 위해)
USER airflow

# 4. 필요한 파이썬 라이브러리 한 번에 설치 (HDFS, Playwright 등)
RUN pip install --no-cache-dir \
    apache-airflow-providers-apache-spark==4.10.0 \
    apache-airflow-providers-postgres==5.12.0 \
    psycopg2-binary \
    pyspark==3.5.3 \
    playwright==1.41.2 \
    beautifulsoup4 \
    hdfs

# 5. Playwright 브라우저 설치
RUN playwright install chromium