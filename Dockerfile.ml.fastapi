# Use an official Python runtime as a parent image
# Consider using a PyTorch image if needed: FROM pytorch/pytorch:latest
FROM python:3.10-slim

# Set the working directory in the container
WORKDIR /app

# Build deps for packages like annoy (via fashion-clip dependency)
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    libgl1 \
    libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

# Copy the requirements file into the container at /app
COPY ml-models/api/requirements.txt .

# Install any needed packages specified in requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

# Copy only ML engine runtime sources (avoid full-repo copy to reduce build time)
COPY ml-models/api /app/ml-models/api
COPY ml-models/weights /app/ml-models/weights

# Make port 8914 available to the world outside this container
EXPOSE 8914

# Define environment variable
ENV PORT=8914

# Run module from ML API directory
WORKDIR /app/ml-models/api

# Run main.py when the container launches using Uvicorn
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8914"]
